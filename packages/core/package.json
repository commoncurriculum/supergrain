{
  "name": "@supergrain/core",
  "version": "0.0.1",
  "description": "Core reactive store implementation for Supergrain.",
  "keywords": [
    "supergrain",
    "core",
    "reactive",
    "store",
    "signals"
  ],
  "license": "MIT",
  "author": "Scott Ames-Messinger",
  "repository": {
    "type": "git",
    "url": "https://github.com/commoncurriculum/supergrain.git",
    "directory": "packages/core"
  },
  "homepage": "https://commoncurriculum.github.io/supergrain/",
  "bugs": {
    "url": "https://github.com/commoncurriculum/supergrain/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint .",
    "test": "vitest run",
    "bench": "vitest bench",
    "bench:core": "vitest bench benchmarks/core-comparison.bench.ts",
    "bench:all": "vitest bench benchmarks/*.bench.ts",
    "bench:additional": "vitest bench benchmarks/additional.bench.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "alien-signals": "^2.0.7"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "solid-js": "^1.9.9",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
