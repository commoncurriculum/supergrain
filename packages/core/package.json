{
  "name": "@storable/core",
  "version": "0.0.1",
  "private": true,
  "description": "Core reactive store implementation for Storable.",
  "keywords": [
    "storable",
    "core",
    "reactive",
    "store",
    "signals"
  ],
  "license": "MIT",
  "author": "Scott Messinger",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint .",
    "test": "vitest run",
    "bench": "vitest bench",
    "bench:core": "vitest bench benchmarks/core-comparison.bench.ts",
    "bench:all": "vitest bench benchmarks/*.bench.ts",
    "bench:additional": "vitest bench benchmarks/additional.bench.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "alien-signals": "^2.0.7",
    "vitest": "^3.2.4"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "solid-js": "^1.9.9"
  }
}
