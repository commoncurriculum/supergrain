{
  "name": "@supergrain/activity",
  "version": "0.0.0",
  "description": "User-activity / presence tracking for Supergrain as a verified XState state chart: active / idle / hidden with short and long idle thresholds.",
  "keywords": [
    "activity",
    "idle",
    "presence",
    "state-machine",
    "supergrain",
    "xstate"
  ],
  "homepage": "https://commoncurriculum.github.io/supergrain/",
  "bugs": {
    "url": "https://github.com/commoncurriculum/supergrain/issues"
  },
  "license": "MIT",
  "author": "Scott Messinger",
  "repository": {
    "type": "git",
    "url": "https://github.com/commoncurriculum/supergrain.git",
    "directory": "packages/activity"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "@supergrain/source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../README.md .",
    "postpack": "rm README.md",
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint -c ../../.oxlintrc.json src/",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@supergrain/kernel": "workspace:*",
    "xstate": "^5.18.2"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "4.1.0"
  }
}
