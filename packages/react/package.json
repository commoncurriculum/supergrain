{
  "name": "@storable/react",
  "version": "0.1.0",
  "description": "React adapter for Storable",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@storable/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.3.1",
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.2",
    "jsdom": "^24.1.0",
    "react": "^18.3.1",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "storable",
    "react",
    "hooks",
    "state-management",
    "reactive",
    "signals"
  ],
  "author": "Scott Messinger",
  "license": "MIT"
}
