{
  "name": "@supergrain/react",
  "version": "1.3.0",
  "description": "React adapter for Supergrain",
  "keywords": [
    "hooks",
    "react",
    "reactive",
    "signals",
    "state-management",
    "supergrain"
  ],
  "homepage": "https://commoncurriculum.github.io/supergrain/",
  "bugs": {
    "url": "https://github.com/commoncurriculum/supergrain/issues"
  },
  "license": "MIT",
  "author": "Scott Messinger",
  "repository": {
    "type": "git",
    "url": "https://github.com/commoncurriculum/supergrain.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../README.md .",
    "postpack": "rm README.md",
    "build": "vite build",
    "bench": "vitest bench --config vitest.bench.config.ts",
    "dev": "vite build --watch",
    "lint": "oxlint -c ../../.oxlintrc.json src/",
    "test": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supergrain/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.18.3",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "4.1.0",
    "playwright": "^1.55.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  }
}
