{
  "name": "@storable/react",
  "version": "0.1.0",
  "description": "React adapter for Storable",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint .",
    "test": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@storable/core": "workspace:*",
    "use-sync-external-store": "^1.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/use-sync-external-store": "^0.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^3.2.4",
    "playwright": "^1.55.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "storable",
    "react",
    "hooks",
    "state-management",
    "reactive",
    "signals"
  ],
  "author": "Scott Messinger",
  "license": "MIT"
}
