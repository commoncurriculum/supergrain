{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "vitest/browser"],
    "lib": ["DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
