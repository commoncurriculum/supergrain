{
  "name": "@supergrain/doc-tests",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation tests for Supergrain examples",
  "keywords": [
    "documentation",
    "examples",
    "supergrain",
    "tests"
  ],
  "license": "MIT",
  "author": "Scott Messinger",
  "type": "module",
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:validate": "vitest run --config vitest.node.config.ts",
    "lint": "oxlint -c ../../.oxlintrc.json tests/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supergrain/core": "workspace:*",
    "@supergrain/react": "workspace:*",
    "@supergrain/store": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.18.3",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "4.1.0",
    "playwright": "^1.55.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "4.1.0"
  }
}
