{
  "name": "@storable/vue",
  "version": "0.0.1",
  "private": true,
  "description": "Vue adapter for Storable.",
  "keywords": [
    "storable",
    "vue",
    "reactive",
    "store",
    "signals",
    "composables"
  ],
  "license": "MIT",
  "author": "Scott Messinger",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@storable/core": "workspace:*",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "vue": "^3.3.0"
  }
}
