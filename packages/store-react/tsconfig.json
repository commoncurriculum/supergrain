{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "jsx": "react-jsx",
    "types": ["node", "vitest/browser"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@supergrain/core": ["../core/src"],
      "@supergrain/store": ["../store/src"],
      "@supergrain/react": ["../react/src"]
    }
  },
  "include": ["src", "tests"]
}
