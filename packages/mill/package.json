{
  "name": "@supergrain/mill",
  "version": "4.0.0",
  "description": "MongoDB-style update operators ($set, $push, $pull, $inc, ...) for Supergrain reactive stores",
  "keywords": [
    "operators",
    "reactive",
    "store",
    "supergrain",
    "update"
  ],
  "homepage": "https://commoncurriculum.github.io/supergrain/",
  "bugs": {
    "url": "https://github.com/commoncurriculum/supergrain/issues"
  },
  "license": "MIT",
  "author": "Scott Messinger",
  "repository": {
    "type": "git",
    "url": "https://github.com/commoncurriculum/supergrain.git",
    "directory": "packages/mill"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@supergrain/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../README.md .",
    "postpack": "rm README.md",
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint -c ../../.oxlintrc.json src/",
    "size": "size-limit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supergrain/kernel": "workspace:*",
    "alien-signals": "^2.0.7"
  },
  "devDependencies": {
    "vitest": "4.1.5"
  },
  "size-limit": [
    {
      "name": "@supergrain/mill",
      "path": "dist/index.js",
      "import": "{ update }",
      "ignore": [
        "@supergrain/kernel",
        "alien-signals"
      ]
    }
  ]
}
