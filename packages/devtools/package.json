{
  "name": "@supergrain/devtools",
  "version": "7.1.0",
  "description": "Devtools for Supergrain: a floating panel to inspect the silo document store (and more, eventually).",
  "keywords": [
    "devtools",
    "inspector",
    "reactive",
    "store",
    "supergrain"
  ],
  "homepage": "https://commoncurriculum.github.io/supergrain/",
  "bugs": {
    "url": "https://github.com/commoncurriculum/supergrain/issues"
  },
  "license": "MIT",
  "author": "Scott Messinger",
  "repository": {
    "type": "git",
    "url": "https://github.com/commoncurriculum/supergrain.git",
    "directory": "packages/devtools"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "@supergrain/source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "@supergrain/source": "./src/react/index.ts",
      "types": "./src/react/index.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../README.md .",
    "postpack": "rm README.md",
    "build": "vite build && pnpm run build:css",
    "build:css": "tailwindcss -i src/devtools.css -o dist/style.css --minify",
    "dev": "vite build --watch",
    "lint": "oxlint -c ../../.oxlintrc.json src/",
    "test": "vitest run",
    "test:react": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@supergrain/kernel": "workspace:*",
    "@supergrain/silo": "workspace:*",
    "react-aria-components": "^1.18.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "4.1.0",
    "effect": "^3.21.2",
    "playwright": "^1.60.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
