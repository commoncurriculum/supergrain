{
  "name": "@supergrain/store",
  "version": "0.1.0",
  "description": "Document-oriented store for Supergrain with TypeScript support",
  "keywords": [
    "document",
    "reactive",
    "store",
    "supergrain",
    "typescript"
  ],
  "homepage": "https://commoncurriculum.github.io/supergrain/",
  "bugs": {
    "url": "https://github.com/commoncurriculum/supergrain/issues"
  },
  "license": "MIT",
  "author": "Scott Messinger",
  "repository": {
    "type": "git",
    "url": "https://github.com/commoncurriculum/supergrain.git",
    "directory": "packages/store"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "oxlint -D correctness -D suspicious -D pedantic -D style src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supergrain/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/browser": "4.1.0",
    "vitest": "4.1.0"
  }
}
