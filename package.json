  "main": "index.js",
  "scripts": {
    "dev": "vitepress dev docs",
    "test": "vitest",
    "test:validate": "pnpm --filter @supergrain/doc-tests run test:validate",
    "bench:core": "vitest bench --root packages/core",
    "lint": "pnpm -r run lint",
    "format": "oxfmt --write .",
