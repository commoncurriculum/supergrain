    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "alien-signals": "^2.0.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.15.0",
    "playwright": "^1.55.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
