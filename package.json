{
  "name": "@commoncurriculum/storable",
  "version": "1.0.0",
  "description": "Framework-agnostic reactive data synchronization library for React and Vue",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.esm.js",
      "require": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.esm.js",
      "require": "./dist/vue/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "oxlint src --deny-warnings -A unicorn/no-empty-file",
    "lint:fix": "oxlint --fix src -A unicorn/no-empty-file",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "format:check": "prettier --check src/**/*.{ts,tsx}",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "vue",
    "data-sync",
    "signals",
    "reactive",
    "state-management",
    "typescript"
  ],
  "author": "Common Curriculum",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@preact/signals-core": "^1.5.0",
    "@preact/signals-react": "^3.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.1.0",
    "oxlint": "^1.14.0",
    "prettier": "^3.1.0",
    "react": "^19.1.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4",
    "vue": "^3.3.0"
  }
}
